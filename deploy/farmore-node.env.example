# farmore-node service config — systemd EnvironmentFile.
#
# Copy to /etc/farmore/node.env on the server, fill in the REPLACE_ME values, then
# `chmod 600` it (it holds the operator private key). setup-oracle.sh installs a copy
# for you if /etc/farmore/node.env does not already exist.
#
# IMPORTANT: systemd does NOT strip inline comments. Keep comments on their own lines;
# never put a "# ..." after a value, or it becomes part of the value.

# Log verbosity (info | debug | trace).
RUST_LOG=info

# --- Network / RPC ---
FARMORE_HOME_RPC_URL=https://sepolia.base.org

# --- Operator key (SECRET) ---
# The node signs from this key. It needs a little Base Sepolia ETH for gas (see runbook).
# On testnet, collateral + inventory are self-funded from the TestUSD faucet (FARMORE_FAUCET=true).
FARMORE_OPERATOR_KEY=REPLACE_ME_OPERATOR_PRIVATE_KEY_0x

# --- Deployed contract addresses (from farmore-contracts deployments/84532.json) ---
FARMORE_SETTLEMENT=REPLACE_ME_0xSETTLEMENT
FARMORE_NAMESPACE=REPLACE_ME_0xNAMESPACE
FARMORE_BOND_VAULT=REPLACE_ME_0xBONDVAULT
FARMORE_FAR=REPLACE_ME_0xFAR
FARMORE_COLLATERAL=REPLACE_ME_0xCOLLATERAL

# --- Operator identity ---
# Your node's handle in the Namespace registry. Auto-registered on first start if free.
FARMORE_HANDLE=my_node

# --- Bond + inventory (testnet: operator's choice, all free via faucet) ---
# Base units of the 6-decimal collateral. 1000000000 = 1,000 tUSD (the reference bond).
FARMORE_BOND_AMOUNT=1000000000
FARMORE_FRONT_INVENTORY=10000000000
FARMORE_COLLATERAL_DECIMALS=6

# --- Chain / loop behaviour ---
FARMORE_DEST_CHAIN_ID=84532
FARMORE_FINALITY_CONFIRMATIONS=2
FARMORE_POLL_MS=4000

# --- Crash-safe state journal (kept under the systemd StateDirectory) ---
FARMORE_STATE_FILE=/var/lib/farmore/farmore-node-state.json

# --- Testnet faucet self-funding. Set to false on mainnet. ---
FARMORE_FAUCET=true
