# farmore-resolver service config — systemd EnvironmentFile.
#
# Copy to /etc/farmore/resolver.env on the server and fill in the REPLACE_ME values.
# The resolver is read-only and holds no funds or keys, so there is no secret here.
# setup-oracle.sh installs a copy for you if /etc/farmore/resolver.env does not exist.
#
# IMPORTANT: systemd does NOT strip inline comments. Keep comments on their own lines.

# Log verbosity (info | debug | trace).
RUST_LOG=info

# --- Network / RPC ---
FARMORE_HOME_RPC_URL=https://sepolia.base.org

# --- Deployed contract addresses (from farmore-contracts deployments/84532.json) ---
FARMORE_NAMESPACE=REPLACE_ME_0xNAMESPACE
FARMORE_SETTLEMENT=REPLACE_ME_0xSETTLEMENT
FARMORE_COLLATERAL=REPLACE_ME_0xCOLLATERAL

# --- HTTP bind address. 0.0.0.0 so it is reachable from the internet. ---
# This is the port you must open in BOTH the Oracle Security List/NSG and the instance firewall.
RESOLVER_BIND=0.0.0.0:8080
