# Farmore Node / resolver configuration. Copy to .env and fill in. NEVER commit real keys.
# All config is read from the environment — nothing is hard-coded.

# --- Node (operator) ---
FARMORE_HOME_RPC_URL=https://sepolia.base.org
FARMORE_OPERATOR_KEY=            # operator private key (use a secrets manager in prod)
FARMORE_SETTLEMENT=
FARMORE_NAMESPACE=
FARMORE_BOND_VAULT=
FARMORE_FAR=
FARMORE_COLLATERAL=
FARMORE_HANDLE=my_node
FARMORE_BOND_AMOUNT=1000000000          # 1,000 tUSD (6 decimals)
FARMORE_FRONT_INVENTORY=10000000000     # 10,000 tUSD working inventory
FARMORE_COLLATERAL_DECIMALS=6
FARMORE_DEST_CHAIN_ID=84532
FARMORE_FINALITY_CONFIRMATIONS=2
FARMORE_POLL_MS=4000
FARMORE_STATE_FILE=farmore-node-state.json
FARMORE_FAUCET=true                     # testnet only: self-fund from the TestUSD faucet

# --- Resolver (standalone) ---
RESOLVER_BIND=0.0.0.0:8080
# reuses FARMORE_HOME_RPC_URL, FARMORE_NAMESPACE, FARMORE_SETTLEMENT, FARMORE_COLLATERAL

# --- Cross-stack e2e ---
# Path to a checked-out farmore-contracts (defaults to the ../farmore-contracts sibling).
FARMORE_CONTRACTS_DIR=
